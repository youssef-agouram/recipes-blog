generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recipe {
  id              Int          @id @default(autoincrement())
  title           String
  slug            String       @unique
  summary         String?
  content         Json
  imageUrl        String?
  images          String[]     @default([])
  isFeatured      Boolean      @default(false)
  isTopArticle    Boolean      @default(false)
  status          String       @default("PUBLISHED")
  prepTime        String?
  cookTime        String?
  servings        Int?
  difficulty      String?
  allowComments   Boolean      @default(true)
  ingredientsJson Json?        @default("[]")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  seo             SeoMeta?
  categories      Category[]   @relation("RecipeCategories")
  ingredients     Ingredient[] @relation("RecipeIngredients")

  @@index([slug])
  @@index([title])
  @@index([isFeatured])
  @@index([isTopArticle])
  @@index([status])
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  recipes Recipe[] @relation("RecipeCategories")

  @@index([name])
}

model Ingredient {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  recipes Recipe[] @relation("RecipeIngredients")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  password String
}

model SeoMeta {
  id          Int     @id @default(autoincrement())
  title       String?
  description String?
  recipeId    Int?    @unique
  recipe      Recipe? @relation(fields: [recipeId], references: [id])
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String
  summary     String?
  imageUrl    String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model HeroSettings {
  id          Int     @id @default(1)
  title       String  @default("Good Food, Good Mood")
  subtitle    String  @default("Explore thousands of handpicked recipes from around the world.")
  imageUrl    String?
  ctaText     String  @default("Explore Recipes")
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
