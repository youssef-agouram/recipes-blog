generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recipe {
  id              Int          @id @default(autoincrement())
  title           String
  slug            String       @unique
  summary         String?
  content         Json
  imageUrl        String?
  images          String[]     @default([])
  isFeatured      Boolean      @default(false)
  isTopArticle    Boolean      @default(false)
  status          String       @default("PUBLISHED")
  prepTime        String?
  cookTime        String?
  totalTime       String?
  servings        Int?
  difficulty      String?
  nutrition       Json?
  views           Int          @default(0)
  allowComments   Boolean      @default(true)
  ingredientsJson Json?        @default("[]")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  seo             SeoMeta?
  categories      Category[]   @relation("RecipeCategories")
  ingredients     Ingredient[] @relation("RecipeIngredients")
  comments        Comment[]

  @@index([slug])
  @@index([title])
  @@index([isFeatured])
  @@index([isTopArticle])
  @@index([status])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  rating    Int?
  status    String   @default("PENDING") // PENDING, APPROVED, SPAM
  likeCount Int      @default(0)
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  parentId  Int?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  name      String?  // For guests
  email     String?  // For guests
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([status])
  @@index([parentId])
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  slug          String         @unique
  description   String?
  imageUrl      String?
  icon          String?
  parentId      Int?
  parent        Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories Category[]     @relation("CategoryHierarchy")
  groupId       Int?
  group         CategoryGroup? @relation(fields: [groupId], references: [id])
  status        String         @default("PUBLISHED")
  displayOnHome Boolean        @default(true)
  isFeatured    Boolean        @default(false)
  menuOrder     Int            @default(0)
  recipes       Recipe[]       @relation("RecipeCategories")

  @@index([name])
  @@index([slug])
}

model CategoryGroup {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  categories  Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([name])
}

model Ingredient {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  recipes Recipe[] @relation("RecipeIngredients")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("Subscriber")
  status    String   @default("Active")
  avatar    String?
  comments  Comment[]
  createdAt DateTime @default(now())
}

model SeoMeta {
  id          Int     @id @default(autoincrement())
  title       String?
  description String?
  recipeId    Int?    @unique
  recipe      Recipe? @relation(fields: [recipeId], references: [id])
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String
  summary     String?
  imageUrl    String?
  category    String?
  isTopArticle Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isTopArticle])
}

model SiteSettings {
  id              Int     @id @default(1)
  logoUrl         String?
  faviconUrl      String?
  footerLogoUrl   String?
  brandName       String  @default("Tasteful")
  tagline         String  @default("Delicious Recipes")
  
  // Navbar settings
  stickyNavbar    Boolean @default(true)
  showSearchBar   Boolean @default(true)
  showAuthButtons Boolean @default(true)
  showTopBar      Boolean @default(true)
  
  // JSON fields for complex structures
  menuItems       Json?   @default("[]")
  profileMenu     Json?   @default("[]")
  footerLinks     Json?   @default("{}")
  socialLinks     Json?   @default("[]")
  copyrightText   String  @default("© {year} Tasteful. All rights reserved.")
  aboutText       String?
  commentSettings Json?   @default("{\"autoApprove\": false, \"allowGuest\": true, \"showRatings\": true, \"notifications\": true}")
}

model HeroSettings {
  id          Int     @id @default(1)
  title       String  @default("Good Food, Good Mood")
  subtitle    String  @default("Explore thousands of handpicked recipes from around the world.")
  imageUrl    String?
  ctaText     String  @default("Explore Recipes")
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Visit {
  id        Int      @id @default(autoincrement())
  path      String
  ip        String?
  userAgent String?
  sessionId String?  // To group visits into sessions
  duration  Int      @default(0) // Seconds spent
  createdAt DateTime @default(now())
}
